{
  "python.analysis.include": [
    "airfoil_library.py",
    "manta_airfoil_tools.py",
    "defaults.py",
    "release_tool"
  ],
  "python.analysis.exclude": [
    "**/__pycache__",
    "build",
    "dist",
    "benchmarks",
    "benchmarks/data",
    "benchmarks/results",
    "database/_local"
  ],
  "files.watcherExclude": {
    "**/__pycache__/**": true,
    "build/**": true,
    "dist/**": true,
    "benchmarks/data/**": true,
    "benchmarks/results/**": true,
    "database/_local/**": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "build": true,
    "dist": true,
    "benchmarks/data": true,
    "benchmarks/results": true,
    "database/_local": true
  }
}
